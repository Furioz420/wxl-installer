<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         WarcraftXL palette: deep charcoal backgrounds + warm gold
         ============================================================ -->

    <Color x:Key="WxlBackgroundColor">#FF121215</Color>
    <Color x:Key="WxlSurfaceColor">#FF1B1B1F</Color>
    <Color x:Key="WxlSurfaceAltColor">#FF23232A</Color>
    <Color x:Key="WxlBorderColor">#FF3A3A42</Color>

    <Color x:Key="WxlGoldColor">#FFD4AF37</Color>
    <Color x:Key="WxlGoldBrightColor">#FFFFC800</Color>
    <Color x:Key="WxlGoldMutedColor">#FF8A6E1A</Color>

    <Color x:Key="WxlTextColor">#FFEAEAEA</Color>
    <Color x:Key="WxlTextMutedColor">#FFA8A8B0</Color>
    <Color x:Key="WxlSuccessColor">#FF64DC64</Color>
    <Color x:Key="WxlDangerColor">#FFFF6464</Color>
    <Color x:Key="WxlWarnColor">#FFFFB464</Color>

    <SolidColorBrush x:Key="WxlBackgroundBrush"   Color="{StaticResource WxlBackgroundColor}" />
    <SolidColorBrush x:Key="WxlSurfaceBrush"      Color="{StaticResource WxlSurfaceColor}" />
    <SolidColorBrush x:Key="WxlSurfaceAltBrush"   Color="{StaticResource WxlSurfaceAltColor}" />
    <SolidColorBrush x:Key="WxlBorderBrush"       Color="{StaticResource WxlBorderColor}" />
    <SolidColorBrush x:Key="WxlGoldBrush"         Color="{StaticResource WxlGoldColor}" />
    <SolidColorBrush x:Key="WxlGoldBrightBrush"   Color="{StaticResource WxlGoldBrightColor}" />
    <SolidColorBrush x:Key="WxlGoldMutedBrush"    Color="{StaticResource WxlGoldMutedColor}" />
    <SolidColorBrush x:Key="WxlTextBrush"         Color="{StaticResource WxlTextColor}" />
    <SolidColorBrush x:Key="WxlTextMutedBrush"    Color="{StaticResource WxlTextMutedColor}" />
    <SolidColorBrush x:Key="WxlSuccessBrush"      Color="{StaticResource WxlSuccessColor}" />
    <SolidColorBrush x:Key="WxlDangerBrush"       Color="{StaticResource WxlDangerColor}" />
    <SolidColorBrush x:Key="WxlWarnBrush"         Color="{StaticResource WxlWarnColor}" />

    <!-- Retint Wpf.Ui accent brushes so buttons/progress use our gold -->
    <SolidColorBrush x:Key="SystemAccentColorBrush"          Color="{StaticResource WxlGoldColor}" />
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush"   Color="{StaticResource WxlGoldColor}" />
    <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="{StaticResource WxlGoldBrightColor}" />
    <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush"  Color="{StaticResource WxlGoldMutedColor}" />

    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush"   Color="{StaticResource WxlGoldColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="{StaticResource WxlGoldBrightColor}" />
    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush"  Color="{StaticResource WxlGoldMutedColor}" />

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"    Color="{StaticResource WxlGoldColor}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush"  Color="{StaticResource WxlGoldBrightColor}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"   Color="{StaticResource WxlGoldMutedColor}" />

    <!-- Small typography helpers -->
    <Style x:Key="WxlTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WxlGoldBrush}" />
        <Setter Property="FontSize"   Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin"     Value="0,0,0,4" />
    </Style>

    <Style x:Key="WxlSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource WxlTextMutedBrush}" />
        <Setter Property="FontSize"     Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin"       Value="0,0,0,16" />
    </Style>

    <Style x:Key="WxlSection" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource WxlSurfaceBrush}" />
        <Setter Property="BorderBrush"      Value="{StaticResource WxlBorderBrush}" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="6" />
        <Setter Property="Padding"          Value="16" />
    </Style>

    <Style x:Key="WxlFieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WxlTextBrush}" />
        <Setter Property="FontSize"   Value="12" />
        <Setter Property="Margin"     Value="0,0,0,4" />
    </Style>

    <Style x:Key="WxlHint" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource WxlTextMutedBrush}" />
        <Setter Property="FontSize"     Value="11" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
