<Page x:Class="WXL_Installer.Views.ColdConvertPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Cold Convert"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,32" MaxWidth="820" HorizontalAlignment="Left">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource WxlTitle}" Text="Cold Convert (optional)" />
                <ui:Button x:Name="BtnHelp"
                           Margin="12,4,0,0"
                           Padding="8,2,8,2"
                           VerticalAlignment="Center"
                           Content="?"
                           ToolTip="What is cold converting?"
                           Click="BtnHelp_Click" />
            </StackPanel>
            <TextBlock Style="{StaticResource WxlSubtitle}"
                       Text="Pre-processes model assets so WarcraftXL can load them faster. Point at your custom assets folder (containing .m2 / .blp files). Safe to skip." />

            <Border Style="{StaticResource WxlSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="Assets folder" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="TxtAssetsPath" Grid.Column="0" TextChanged="TxtAssets_Changed" />
                        <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="Browse…" Click="BrowseAssets_Click" />
                    </Grid>
                    <TextBlock Style="{StaticResource WxlHint}"
                               Text="Folder containing the .m2 / .blp / .wmo / .adt files to convert." />

                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="Output folder" Margin="0,12,0,0" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="TxtOutputPath" Grid.Column="0" TextChanged="TxtOutput_Changed" />
                        <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="Browse…" Click="BrowseOutput_Click" />
                    </Grid>
                    <TextBlock Style="{StaticResource WxlHint}"
                               Text="Folder where the converted (baked) assets will be written." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WxlSection}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:Button x:Name="BtnRun"
                                   Appearance="Primary"
                                   Content="Run Cold Convert"
                                   Click="BtnRun_Click" />
                    </StackPanel>

                    <ProgressBar x:Name="Progress"
                                 Height="8"
                                 Minimum="0" Maximum="100"
                                 Foreground="{StaticResource WxlGoldBrush}"
                                 Background="{StaticResource WxlSurfaceAltBrush}"
                                 Margin="0,0,0,8" />

                    <TextBlock x:Name="LblStatus"
                               Style="{StaticResource WxlHint}"
                               Text="Enter your assets folder and click Run Cold Convert, or skip this step." />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
