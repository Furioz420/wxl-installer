<Page x:Class="WXL_Installer.Views.ColdConvertPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Cold Convert"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,32" MaxWidth="820" HorizontalAlignment="Left">

            <TextBlock Style="{StaticResource WxlTitle}" Text="Cold Convert (optional)" />
            <TextBlock Style="{StaticResource WxlSubtitle}"
                       Text="Cold converting pre-bakes M2 / WMO / ADT / BLP assets so the TLK 3.3.5a client loads them natively, removing WXL's hot-conversion cost at runtime. Optional; only needed before shipping a build." />

            <Border Style="{StaticResource WxlSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="What it does" />
                    <TextBlock Style="{StaticResource WxlHint}" TextWrapping="Wrap">
                        <Run Text="• M2 / Anim — animation id fixes, ribbon emitters, external .anim unwrapping, shadow-swing billboard fix." />
                        <LineBreak />
                        <Run Text="• WMO — doodads, portals/culling, collision, lights, liquid, vertex-color neutralization." />
                        <LineBreak />
                        <Run Text="• ADT — terrain holes, water, doodad/WMO placements, texture layers, area/ground-effect ids, WDT/WDL companion files." />
                        <LineBreak />
                        <Run Text="• BLP — DXT5 transcoding, per-folder size caps." />
                    </TextBlock>

                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="Links" Margin="0,12,0,0" />
                    <TextBlock>
                        <Hyperlink NavigateUri="https://github.com/WarcraftXL/wxl-cold-converter"
                                   RequestNavigate="Hyperlink_RequestNavigate">Repository</Hyperlink>
                        <Run Text="    " />
                        <Hyperlink NavigateUri="https://github.com/WarcraftXL/wxl-cold-converter/releases"
                                   RequestNavigate="Hyperlink_RequestNavigate">All releases</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WxlSection}">
                <StackPanel>
                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="Cold Converter" />
                    <TextBlock x:Name="LblInstalled" Style="{StaticResource WxlHint}" TextWrapping="Wrap"
                               Text="Not downloaded yet." />

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <ui:Button x:Name="BtnLaunch"
                                   Appearance="Primary"
                                   Content="Download &amp; run latest"
                                   Click="BtnLaunch_Click" />
                        <ui:Button x:Name="BtnReinstall"
                                   Content="Re-download"
                                   Margin="8,0,0,0"
                                   Click="BtnReinstall_Click" />
                        <ui:Button x:Name="BtnOpenFolder"
                                   Content="Open folder"
                                   Margin="8,0,0,0"
                                   Click="BtnOpenFolder_Click" />
                    </StackPanel>

                    <ProgressBar x:Name="Progress"
                                 Height="8"
                                 Minimum="0" Maximum="100"
                                 Foreground="{StaticResource WxlGoldBrush}"
                                 Background="{StaticResource WxlSurfaceAltBrush}"
                                 Margin="0,12,0,8" />

                    <TextBlock x:Name="LblStatus"
                               Style="{StaticResource WxlHint}"
                               Text="The converter is a separate GUI. We'll download the latest release and open it for you." />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
