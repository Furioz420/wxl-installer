<Page x:Class="WXL_Installer.Views.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Welcome"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,32" MaxWidth="820" HorizontalAlignment="Left">

            <Image x:Name="Logo"
                   Height="72"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,16"
                   Stretch="Uniform" />

            <TextBlock Style="{StaticResource WxlTitle}"
                       Text="Welcome to the WarcraftXL Installer" />
            <TextBlock Style="{StaticResource WxlSubtitle}"
                       Text="Configure your install paths below. Everything else uses the side menu — each step is enabled once its prerequisites are met." />

            <Border Style="{StaticResource WxlSection}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="WXL install folder" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="TxtWxlPath" Grid.Column="0" TextChanged="Path_Changed" />
                        <ui:Button x:Name="BtnBrowseWxl" Grid.Column="1" Margin="8,0,0,0"
                                   Content="Browse…" Click="BrowseWxl_Click" />
                    </Grid>
                    <TextBlock Style="{StaticResource WxlHint}"
                               Text="Folder where wxl-core will be installed (must contain CMakeLists.txt after Core install)." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource WxlSection}">
                <StackPanel>
                    <TextBlock Style="{StaticResource WxlFieldLabel}" Text="WoW client folder" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="TxtClientPath" Grid.Column="0" TextChanged="Path_Changed" />
                        <ui:Button x:Name="BtnBrowseClient" Grid.Column="1" Margin="8,0,0,0"
                                   Content="Browse…" Click="BrowseClient_Click" />
                    </Grid>
                    <TextBlock x:Name="LblClientStatus" Style="{StaticResource WxlHint}" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <ui:Button x:Name="BtnCheckUpdate"
                           Content="Check for updates"
                           Click="BtnCheckUpdate_Click" />
                <TextBlock x:Name="LblVersion"
                           Style="{StaticResource WxlHint}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <TextBlock x:Name="LblUpdateStatus"
                           Style="{StaticResource WxlHint}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
