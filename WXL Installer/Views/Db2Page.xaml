<Page x:Class="WXL_Installer.Views.Db2Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="DB2 Files"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32,40,32" MaxWidth="820" HorizontalAlignment="Left">

            <TextBlock Style="{StaticResource WxlTitle}" Text="Install required DB2 files" />
            <TextBlock Style="{StaticResource WxlSubtitle}"
                       Text="WarcraftXL requires a small set of DB2 files (ModelFileData, TextureFileData, …). They will be placed inside the next free Data\Patch-&lt;letter&gt;.mpq\DBFilesClient folder of your WoW client. Your original client files are not modified." />

            <Border Style="{StaticResource WxlSection}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:Button x:Name="BtnInstall"
                                   Appearance="Primary"
                                   Content="Install required DB2 files"
                                   Click="BtnInstall_Click" />
                        <ProgressBar x:Name="Progress"
                                     Width="360" Height="8"
                                     Minimum="0" Maximum="100"
                                     Margin="16,0,0,0"
                                     VerticalAlignment="Center"
                                     Foreground="{StaticResource WxlGoldBrush}"
                                     Background="{StaticResource WxlSurfaceAltBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="LblStatus"
                               Style="{StaticResource WxlHint}"
                               Text="Click the button to download and install the required DB2 files." />

                    <TextBlock Foreground="{StaticResource WxlGoldBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               Margin="0,14,0,4"
                               Text="Files that will be installed" />
                    <TextBlock x:Name="LblRequiredTarget"
                               Style="{StaticResource WxlHint}"
                               Margin="0,0,0,6"
                               Text="Target patch will be resolved when you set a WoW client." />
                    <ItemsControl x:Name="RequiredFilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FileName}"
                                               Foreground="{StaticResource WxlTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TargetDisplay}"
                                               Margin="16,0,0,0"
                                               Foreground="{StaticResource WxlTextMutedBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="LblRequiredListStatus"
                               Style="{StaticResource WxlHint}"
                               Margin="0,4,0,0"
                               Text="Loading file list…" />
                </StackPanel>
            </Border>

            <Border x:Name="EquipDb2Section"
                    Style="{StaticResource WxlSection}"
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource WxlGoldBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               Text="Equip module DB2 / DBC files" />
                    <TextBlock Style="{StaticResource WxlHint}"
                               Margin="0,4,0,8"
                               Text="wxl-equip-module-DB2 ships with DBCandDB2.zip. These extra client files are required for the equip module to work. Extract them into your client's DBFilesClient patch alongside the standard DB2 files above." />
                    <TextBlock x:Name="LblEquipZipPath"
                               Style="{StaticResource WxlHint}"
                               FontStyle="Italic"
                               Margin="0,0,0,4" />
                    <TextBlock x:Name="LblEquipTarget"
                               Style="{StaticResource WxlHint}"
                               Margin="0,0,0,8" />
                    <ItemsControl x:Name="EquipFilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FileName}"
                                               Foreground="{StaticResource WxlTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TargetDisplay}"
                                               Margin="16,0,0,0"
                                               Foreground="{StaticResource WxlTextMutedBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
